Q1.Consecutive Days - Find all the users who were active for 3 consecutive days or more.

WITH t AS (
    SELECT 
        user_id,
        record_date,
        ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY record_date) AS rn
    FROM (
        SELECT DISTINCT user_id, record_date 
        FROM sf_events
    ) x
)
SELECT user_id
FROM t
GROUP BY user_id, DATE_SUB(record_date, INTERVAL rn DAY)
HAVING COUNT(*) >= 3;

Q2. Find all posts which were reacted to with a heart. For such posts output all columns from facebook_posts table.
SELECT *
FROM facebook_posts
WHERE post_id IN (
    SELECT post_id
    FROM facebook_reactions
    WHERE reaction = 'heart'
);

Q3.Best selling item-of month ignore cancel and return orders
SELECT month, description, total_paid
FROM (
    SELECT 
        MONTH(invoicedate) AS month,
        description,
        SUM(unitprice * quantity) AS total_paid,
        ROW_NUMBER() OVER (
            PARTITION BY MONTH(invoicedate)
            ORDER BY SUM(unitprice * quantity) DESC
        ) AS rn
    FROM online_retail
    WHERE quantity > 0
      AND invoiceno NOT LIKE 'C%'
    GROUP BY MONTH(invoicedate), description
) t
WHERE rn = 1;

Q4. Rank Variance per Country
SELECT * FROM (
    WITH monthly_comments AS (
        SELECT 
            u.country,
            YEAR(c.created_at) AS yr,
            MONTH(c.created_at) AS mn,
            SUM(c.number_of_comments) AS total_comments
        FROM fb_comments_count c
        JOIN fb_active_users u 
            ON c.user_id = u.user_id
        WHERE c.created_at BETWEEN '2019-12-01' AND '2020-01-31'
        GROUP BY u.country, YEAR(c.created_at), MONTH(c.created_at)
    ),
    ranked AS (
        SELECT 
            country,
            yr,
            mn,
            total_comments,
            DENSE_RANK() OVER (
                PARTITION BY yr, mn
                ORDER BY total_comments DESC
            ) AS rnk
        FROM monthly_comments
    ),
     pivoted AS (
        SELECT 
            country,
            MAX(CASE WHEN yr = 2019 AND mn = 12 THEN rnk END) AS dec_rank,
            MAX(CASE WHEN yr = 2020 AND mn = 1 THEN rnk END) AS jan_rank
        FROM ranked
        GROUP BY country
    )
    
    SELECT country
    FROM pivoted
    WHERE jan_rank < dec_rank
) t;
